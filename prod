version: "3.8"

services:
  checkmk-raw:
    image: "checkmk/check-mk-raw:latest"
    container_name: "checkmk"
    environment:
      #- CMK_PASSWORD=mypassword
      #- MAIL_RELAY_HOST=mailrelay.example.com
      #- CMK_SITE_ID=cmknew
      #- CMK_LIVESTATUS_TCP=on
      - TZ=Europe/Berlin
      - CMK_SITE_ID=cmk
    
    deploy:
      resources:
        limits:
          # cpus: '2' # Synology und TerraMaster bestätigen, dass ihre Kernel keine Docker‑CPU‑Limits unterstützen.
          memory: 4g
    
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    
    volumes:
      - /volume1/docker/checkmk:/omd/sites
      #- /volume1/docker/checkmk/backups:/backup
      - /etc/localtime:/etc/localtime:ro
    
    tmpfs:
      - /opt/omd/sites/cmk/tmp:uid=1000,gid=1000,rw,noexec,nosuid,size=512m
      #- /omd/sites/cmk/tmp:uid=1000,gid=1000,rw,noexec,nosuid,size=512m
      #- /tmp:rw,noexec,nosuid,size=512m
    
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/cmk/check_mk/login.py"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    
    ports:
      - 8722:5000
      #- 8000:8000
      #- "162:162/udp"
      #- "514:514/udp"
      #- "514:514/tcp"
      #- "6557:6557/tcp"
    
    restart: on-failure:5

volumes:
  checkmk:

